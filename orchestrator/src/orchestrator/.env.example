# Copy to .env.local (local dev) and fill in values.
# APP_ENV controls which file is loaded: local (default) | dev | prod
#
# For dev/prod on ECS, set CONFIG_PROVIDER=aws instead of using this file.
# The orchestrator will fetch config from SSM / Secrets Manager at startup.

# ─── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/data_pipelines_db

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Region is always needed. Credentials are NOT set here — use an IAM role in ECS
# or your local AWS profile (~/.aws/credentials) for dev work.
AWS_REGION=ap-south-1

# ─── Config provider (local only, aws for ECS) ────────────────────────────────
# CONFIG_PROVIDER=aws
# AWS_PARAM_PREFIX=data-pipelines-dev   # or data-pipelines for prod

# ─── Scheduler ────────────────────────────────────────────────────────────────
JOB_POLL_INTERVAL_SECONDS=30
