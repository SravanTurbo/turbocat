# Copy to .env.local (local dev), .env.dev, or .env.prod and fill in values.
# APP_ENV controls which file is loaded: local (default) | dev | prod
# In CI/CD you can skip the file entirely and set DATABASE_URL directly as an env var.

# ─── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/data_pipelines_db

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Scheduler ────────────────────────────────────────────────────────────────
JOB_POLL_INTERVAL_SECONDS=30
